generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String                 @id @default(uuid())
  name                  String?
  email                 String                 @unique
  role                  String                 @default("CLIENTE")
  createdAt             DateTime               @default(now())
  countryCode           String?
  suiteNo               String?                @unique
  dateOfBirth           DateTime?
  address               String?
  cityZip               String?
  country               String?
  phone                 String?
  referralCode          String?                @unique
  referredBy            String?
  shippingBalance       Float                  @default(0.0)
  stripeCustomerId      String?                @unique
  image                 String?
  password              String?
  referralRewardPaid    Boolean                @default(false)
  resetToken            String?                @unique
  resetTokenExpiry      DateTime?
  walletBalance         Float                  @default(0.0)
  emailVerified         DateTime?
  planType              String?                @default("STANDARD")
  noConsolidationFee    Boolean                @default(false)
  tenant_id             String?                @db.Uuid
  addresses             Address[]
  consolidatedShipments ConsolidatedShipment[]
  mailItems             MailItem[]
  mailPickupRequests    MailPickupRequest[]
  mailboxSubscription   MailboxSubscription?
  mailboxTransactions   MailboxTransaction[]
  notifications         Notification[]
  packages              Package[]
  paymentMethods        PaymentMethod[]
  assignedTasks         PickupRequest[]        @relation("DriverAssignments")
  pickupRequests        PickupRequest[]
  shopperOrders         ShopperOrder[]
  tenant                Tenant?                @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model PaymentMethod {
  id                    String   @id @default(uuid())
  createdAt             DateTime @default(now())
  stripePaymentMethodId String   @unique
  brand                 String
  last4                 String
  expMonth              Int
  expYear               Int
  isDefault             Boolean  @default(false)
  isBackup              Boolean  @default(false)
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Package {
  id                     String                @id @default(uuid())
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  status                 String
  description            String?
  storagePaidUntil       DateTime?
  storageDebt            Float                 @default(0.0)
  courier                String?
  declaredValue          Float?                @default(0.0)
  weightLbs              Float?
  lengthIn               Float?
  widthIn                Float?
  heightIn               Float?
  photoUrlMiami          String?
  receiptUrl             String?
  invoiceUrl             String?
  carrierTrackingNumber  String?
  gmcTrackingNumber      String                @unique
  estimatedArrival       DateTime?
  userId                 String
  consolidatedShipmentId String?
  courierService         String?
  customsItems           Json?
  deliveredBy            String?
  deliveryPhotoUrl       String?
  deliverySignature      String?
  finalTrackingNumber    String?
  selectedCourier        String?
  shippingAddress        String?
  shippingLabelUrl       String?
  shippingProcessingFee  Float?                @default(0.0)
  shippingSubtotal       Float?                @default(0.0)
  shippingTotalPaid      Float?                @default(0.0)
  stripePaymentId        String?
  tookanLink             String?
  serviceType            String?               @default("SHIPPING_INTL")
  awbDocumentUrl         String?
  extraCharges           Json?
  tenant_id              String?               @db.Uuid
  consolidatedShipment   ConsolidatedShipment? @relation(fields: [consolidatedShipmentId], references: [id])
  tenant                 Tenant?               @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gmcTrackingNumber])
  @@index([userId])
}

model ConsolidatedShipment {
  id                     String    @id @default(uuid())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  gmcShipmentNumber      String    @unique
  destinationCountryCode String?
  status                 String
  storagePaidUntil       DateTime?
  selectedCourier        String?
  courierService         String?
  finalTrackingNumber    String?
  shippingLabelUrl       String?
  paymentId              String?
  weightLbs              Float?
  subtotalAmount         Float?    @default(0.0)
  processingFee          Float?    @default(0.0)
  totalAmount            Float?
  widthIn                Float?
  heightIn               Float?
  lengthIn               Float?
  userId                 String
  customsItems           Json?
  declaredValue          Float?    @default(0.0)
  deliveredBy            String?
  serviceType            String    @default("CONSOLIDATION")
  shippingAddress        String?
  awbDocumentUrl         String?
  auraDetails            Json?
  extraCharges           Json?
  tenant_id              String?   @db.Uuid
  tenant                 Tenant?   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  packages               Package[]

  @@index([gmcShipmentNumber])
  @@index([userId])
}

model PickupRequest {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  serviceType      String   @default("SHIPPING")
  originAddress    String
  originCity       String
  pickupDate       DateTime
  description      String
  contactPhone     String
  dropOffAddress   String?
  dropOffCity      String?
  dropOffContact   String?
  dropOffPhone     String?
  subtotal         Float?   @default(0.0)
  processingFee    Float?   @default(0.0)
  totalPaid        Float?   @default(0.0)
  stripePaymentId  String?
  weightInfo       String?
  volumeInfo       String?
  photoPickupUrl   String?
  photoDeliveryUrl String?
  status           String   @default("PENDIENTE")
  userId           String
  driverId         String?
  signatureUrl     String?
  tookanLink       String?
  tenant_id        String?  @db.Uuid
  driver           User?    @relation("DriverAssignments", fields: [driverId], references: [id])
  tenant           Tenant?  @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  title     String
  message   String
  href      String?
  isRead    Boolean  @default(false)
  type      String   @default("INFO")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}

model Address {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  fullName    String
  address     String
  cityZip     String
  country     String
  countryCode String?
  phone       String?
  isDefault   Boolean  @default(false)
  userId      String
  city        String?
  state       String?
  zip         String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MailboxSubscription {
  id                   String                @id @default(uuid())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  planType             String
  status               String                @default("PENDING_USPS")
  uspsForm1583Url      String?
  primaryIdUrl         String?
  secondaryIdUrl       String?
  rejectionReason      String?
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?               @unique
  userId               String                @unique
  additionalRecipients AdditionalRecipient[]
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdditionalRecipient {
  id              String              @id @default(uuid())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  fullName        String
  email           String?
  uspsForm1583Url String?
  primaryIdUrl    String?
  secondaryIdUrl  String?
  status          String              @default("PENDING_USPS")
  rejectionReason String?
  subscriptionId  String
  subscription    MailboxSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model MailItem {
  id               String              @id @default(uuid())
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  trackingNumber   String?             @unique
  senderName       String?
  weightOz         Float?
  lengthIn         Float?
  widthIn          Float?
  heightIn         Float?
  isDamaged        Boolean             @default(false)
  envelopeImageUrl String
  scannedDocUrl    String?
  status           String              @default("UNREAD")
  receivedAt       DateTime            @default(now())
  userId           String
  cargoPackageId   String?             @unique
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  pickupRequests   MailPickupRequest[] @relation("MailItemToMailPickupRequest")
}

model MailboxTransaction {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  amount          Float
  description     String
  status          String   @default("COMPLETED")
  stripePaymentId String?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShopperOrder {
  id               String        @id @default(cuid())
  userId           String
  status           String        @default("PENDING_QUOTE")
  itemsSubtotal    Float         @default(0)
  usTaxes          Float         @default(0)
  domesticShipping Float         @default(0)
  gmcShopperFee    Float         @default(0)
  stripeFee        Float         @default(0)
  totalAmount      Float         @default(0)
  stripePaymentId  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  serviceType      String        @default("PERSONAL_SHOPPER")
  tenant_id        String?       @db.Uuid
  items            ShopperItem[]
  tenant           Tenant?       @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ShopperItem {
  id            String       @id @default(cuid())
  orderId       String
  storeName     String?
  productUrl    String
  name          String?
  details       String?
  quantity      Int          @default(1)
  declaredPrice Float
  actualPrice   Float?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  tenant_id     String?      @db.Uuid
  order         ShopperOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenants       Tenant?      @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([orderId])
}

model MailPickupRequest {
  id            String     @id @default(cuid())
  userId        String
  scheduledDate DateTime
  scheduledTime String
  status        String     @default("PENDING")
  createdAt     DateTime   @default(now())
  completedAt   DateTime?
  user          User       @relation(fields: [userId], references: [id])
  mailItems     MailItem[] @relation("MailItemToMailPickupRequest")
}

model AmazonProduct {
  id           String   @id @default(uuid())
  title        String
  price        String
  imageUrl     String
  affiliateUrl String
  category     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

model Tenant {
  id                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_name           String
  slug                   String                 @unique
  custom_domain          String?                @unique
  logo_url               String?
  primary_color          String?                @default("#000000")
  secondary_color        String?                @default("#ffffff")
  owner_name             String?
  owner_email            String                 @unique
  owner_phone            String?
  plan                   String?                @default("starter")
  plan_status            String?                @default("active")
  setup_fee_paid         Boolean?               @default(false)
  monthly_fee            Decimal?               @default(149.00) @db.Decimal
  next_billing_date      DateTime?              @db.Timestamp(6)
  easypost_api_key       String?
  stripe_publishable_key String?
  stripe_secret_key      String?
  created_at             DateTime?              @default(now()) @db.Timestamp(6)
  updated_at             DateTime?              @default(now()) @updatedAt @db.Timestamp(6)
  consolidatedShipments  ConsolidatedShipment[]
  packages               Package[]
  pickupRequests         PickupRequest[]
  ShopperItem            ShopperItem[]
  shopperOrders          ShopperOrder[]
  users                  User[]

  @@map("tenants")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
